CONTRAST__AGENT__TOKEN="Your_API_Token_Here"

# Prefix used to namespace app names in Contrast. Final app name format: {UNIQ_NAME}-cargocats-{service}
# Use something that identifies you (e.g. your name or initials). Do NOT use "cargocats" (avoids cargocats-cargocats-{service}).
CONTRAST__UNIQ__NAME="Your_Unique_Name_Here"

#optional for ADR data collection and deletion
CONTRAST__API__KEY="Your_API_Key_Here"
CONTRAST__API__AUTHORIZATION="Your_Authorization_Token_Here"
